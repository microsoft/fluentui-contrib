{
  "name": "cap-foundations-react",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cap-foundations/react/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@fluentui-contrib/nx-plugin:build"
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "packages/cap-foundations/react/**/*.ts",
          "packages/cap-foundations/react/**/*.tsx",
          "packages/cap-foundations/react/package.json"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/cap-foundations/react/jest.config.cts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": { "ci": true, "codeCoverage": true }
      }
    },
    "type-check": {
      "executor": "@fluentui-contrib/nx-plugin:type-check"
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "port": 4401,
        "configDir": "packages/cap-foundations/react/.storybook"
      },
      "configurations": {
        "ci": { "quiet": true }
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/cap-foundations-react",
        "configDir": "packages/cap-foundations/react/.storybook"
      },
      "configurations": {
        "ci": { "quiet": true }
      }
    }
  }
}
